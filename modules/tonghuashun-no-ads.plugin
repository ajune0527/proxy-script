#!name= 同花顺净化
#!desc= 拦截同花顺广告请求，过滤首页多余卡片。每个卡片标题独立开关控制。
#!author= ajune
#!system= iOS
#!tag= 去广告
#!loon_version= 3.2.1(733)
#!icon= https://raw.githubusercontent.com/ajune0527/proxy-script/main/tonghuashun.png
#!homepage= https://github.com/ajune0527/proxy-script
#!date= 2026-06-17 13:02:00

[Argument]
enable = switch,true,tag=启用卡片过滤,desc=关闭后不过滤首页任何卡片
炒股大赛 = switch,true,tag=炒股大赛,desc=过滤首页「炒股大赛」卡片
k线训练营 = switch,true,tag=k线训练营,desc=过滤首页「k线训练营」卡片
全球机会 = switch,true,tag=全球机会,desc=过滤首页「全球机会」卡片
