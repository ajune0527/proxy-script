并购重组 = switch,false,tag=并购重组,desc=过滤首页「并购重组」卡片
自选大事 = switch,false,tag=自选大事,desc=过滤首页「自选大事」卡片
热门股票 = switch,false,tag=热门股票,desc=过滤首页「热门股票」卡片
资金流入 = switch,false,tag=资金流入,desc=过滤首页「资金流入」卡片
热门板块 = switch,false,tag=热门板块,desc=过滤首页「热门板块」卡片
每日复盘 = switch,false,tag=每日复盘,desc=过滤首页「每日复盘」卡片
今天炒什么 = switch,false,tag=今天炒什么,desc=过滤首页「今天炒什么」卡片
黄金 = switch,false,tag=黄金,desc=过滤首页「黄金」卡片
涨停聚焦 = switch,false,tag=涨停聚焦,desc=过滤首页「涨停聚焦」卡片
净利润断层 = switch,false,tag=净利润断层,desc=过滤首页「净利润断层」卡片
自定义过滤 = input, "自定义过滤卡片，多个卡片用逗号分隔", tag=自定义过滤,desc=自定义过滤卡片，多个卡片用逗号分隔
